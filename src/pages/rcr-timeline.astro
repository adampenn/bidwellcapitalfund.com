.gantt-bar.consolidated-bar { opacity: 0.7; border: 1px solid rgba(255,255,255,0.4); }
.gantt-bar.consolidated-bar:hover { opacity: 1; }

/* ---- App Footer ---- */
.app-footer { border-top: 1px solid #e5e5ea; padding: 1.5rem 0; margin-top: 2rem; }
.app-footer p { font-size: 0.6875rem; color: #9b9ba8; max-width: 80ch; }

/* ---- PDF Overlay Styles ---- */
#pdf-overlay {
  position: fixed; inset: 0; z-index: 2000; background: #fff;
  overflow: auto;
}
.pdf-content {
  max-width: 1100px; margin: 0 auto; padding: 2.5rem 2rem;
  font-family: 'DM Sans', system-ui, sans-serif; color: #1a1a2e;
}
.pdf-header { margin-bottom: 2rem; border-bottom: 2px solid #1a1a2e; padding-bottom: 1.25rem; }
.pdf-brand { font-family: 'DM Serif Display', Georgia, serif; font-size: 1.1rem; color: #1a1a2e; margin-bottom: 0.25rem; }
.pdf-title { font-family: 'DM Serif Display', Georgia, serif; font-size: 1.75rem; margin-bottom: 0.25rem; }
.pdf-subtitle { font-size: 0.875rem; color: #6b6b80; }
.pdf-footer { margin-top: 2rem; padding-top: 1rem; border-top: 1px solid #e5e5ea; }
.pdf-footer p { font-size: 0.6875rem; color: #9b9ba8; }
.pdf-gantt-container { overflow: visible; margin: 1.5rem 0; }

/* ---- Print Styles ---- */
@media print {
  .no-print { display: none !important; }
  #auth-screen { display: none !important; }
  .app-header { display: none !important; }
  .app-footer { display: none !important; }
  .output-section { padding: 0; }
  .gantt-container { overflow: visible !important; border: 1px solid #ccc; break-inside: avoid; }
  .gantt-chart-area { overflow: visible !important; }
  .schedule-table { font-size: 0.65rem; }
  .schedule-table tbody td { padding: 0.25rem 0.5rem; }
  body { font-size: 12px; }
  .section-heading { font-size: 1.1rem; }
  .summary-card { break-inside: avoid; }
  .table-section { break-before: page; }
}

/* ---- Compact mode ---- */
body.compact .gantt-label-row { height: 20px !important; font-size: 0.5625rem; }
body.compact .gantt-row { height: 20px !important; }
body.compact .gantt-bar { top: 2px !important; height: 16px !important; }
body.compact .schedule-table tbody td { padding: 0.25rem 0.5rem; font-size: 0.75rem; }
