---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Bidwell Capital Fund — Building Generational Wealth Through Real Assets">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <span class="section-label fade-up fade-up-1">Bidwell Capital Fund</span>
      <h1 class="fade-up fade-up-2">Building generational wealth<br/>through real assets</h1>
      <p class="hero-sub fade-up fade-up-3">We invest in tax-advantaged, income-producing real assets: commercial credit, short-term rentals, and energy. Over $42 million in investor capital deployed.</p>
      <div class="hero-actions fade-up fade-up-4">
        <a href="/track-record" class="btn btn-primary">View Track Record</a>
        <a href="/about" class="btn btn-outline">Our Strategy</a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section">
    <div class="container">
      <div class="grid-3">
        <div class="stat-card card fade-up fade-up-2">
          <span class="stat-value">$42M+</span>
          <span class="stat-label">Investor Capital Deployed</span>
        </div>
        <div class="stat-card card fade-up fade-up-3">
          <span class="stat-value">18.1%</span>
          <span class="stat-label">Avg. Gross Yield</span>
        </div>
        <div class="stat-card card fade-up fade-up-4">
          <span class="stat-value">15</span>
          <span class="stat-label">Deals Funded</span>
        </div>
      </div>
      <p class="disclaimer" style="margin-top: 1.5rem; text-align: center;">Past performance is not indicative of future results. All investments carry risk, including loss of principal.</p>
    </div>
  </section>

  <!-- What We Do -->
  <section class="section" style="background: var(--bg-secondary);">
    <div class="container">
      <span class="section-label">What We Do</span>
      <h2>Real assets, real returns</h2>
      <p style="margin-bottom: 2.5rem;">Bidwell Capital Fund focuses on asset classes that generate income, provide tax advantages, and are backed by tangible collateral. We are operators and allocators, not salespeople.</p>
      <div class="grid-3">
        <div class="card">
          <h3>Commercial Credit</h3>
          <p>Preferred equity and mezzanine debt positions in commercial real estate: multifamily, industrial, medical office, and more. Structured with downside protection through forced sale and take-over rights.</p>
        </div>
        <div class="card">
          <h3>Short-Term Rentals</h3>
          <p>Direct ownership and management of vacation rental properties. Tax-advantaged through cost segregation and bonus depreciation, with strong cash flow from nightly rates.</p>
        </div>
        <div class="card">
          <h3>Energy</h3>
          <p>Working interest positions in oil and gas. Significant tax deductions through intangible drilling costs, with exposure to a commodity backed by real-world demand.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container" style="text-align: center;">
      <span class="section-label">Get Started</span>
      <h2>Interested in learning more?</h2>
      <p style="margin: 1rem auto 2rem;">We work with accredited investors who want alternatives to traditional markets. Reach out to start a conversation.</p>
      <a href="/contact" class="btn btn-primary">Contact Us</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: 6rem 0 4rem;
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .hero h1 {
    margin: 0.5rem 0 1.5rem;
  }

  .hero-sub {
    font-size: 1.125rem;
    max-width: 55ch;
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .stat-card {
    text-align: center;
    padding: 2rem;
  }

  .stat-value {
    display: block;
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }
</style>
