---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Track Record - Bidwell Capital" description="Deal-by-deal transparency across all Bidwell Capital strategies.">
  <section class="hero-sm">
    <div class="container">
      <span class="section-label fade-up fade-up-1">Track Record</span>
      <h1 class="fade-up fade-up-2">Our strategies, transparently</h1>
      <p class="fade-up fade-up-3">We believe in full transparency. Below is a look at our active strategies and their performance. <a href="/about" style="color: var(--accent);">Learn more about how we invest &rarr;</a></p>
    </div>
  </section>

  <!-- Company-wide stat -->
  <section class="section" style="padding-top: 2rem; padding-bottom: 1rem;">
    <div class="container">
      <div class="grid-3">
        <div class="card stat-card">
          <span class="stat-label">Total Distributed</span>
          <span class="stat-value">$547,270</span>
        </div>
        <div class="card stat-card">
          <span class="stat-label">Active Strategies</span>
          <span class="stat-value">3</span>
        </div>
        <div class="card stat-card">
          <span class="stat-label">Investor Capital Raised</span>
          <span class="stat-value">$10M+</span>
        </div>
      </div>
      <p class="disclaimer" style="margin-top: 1rem; text-align: center;">Past performance is not indicative of future results. All investments carry risk, including loss of principal.</p>
    </div>
  </section>

  <!-- Strategy Tabs -->
  <section class="section" style="padding-top: 1rem;">
    <div class="container">
      <div class="strategy-tabs" id="strategy-tabs">
        <button class="strategy-tab active" data-tab="credit">Private Credit</button>
        <button class="strategy-tab" data-tab="realestate">Multifamily Real Estate</button>
        <button class="strategy-tab" data-tab="energy">Oil &amp; Gas</button>
      </div>

      <!-- Private Credit Panel -->
      <div class="tab-panel active" id="panel-credit">
        <div class="grid-3" style="margin-bottom: 2rem;" id="kpi-grid">
          <div class="card stat-card">
            <span class="stat-label">Portfolio Size</span>
            <span class="stat-value" id="kpi-size">-</span>
          </div>
          <div class="card stat-card">
            <span class="stat-label">Gross Yield</span>
            <span class="stat-value" id="kpi-yield">-</span>
          </div>
          <div class="card stat-card">
            <span class="stat-label">Combined LTV/LTC</span>
            <span class="stat-value" id="kpi-ltv">-</span>
          </div>
        </div>

        <div class="pills" id="pccf-pills" style="margin-bottom: 1.5rem;"></div>

        <div class="grid-2" style="margin-bottom: 2rem;">
          <div class="card chart-card">
            <h3>Portfolio Asset Mix</h3>
            <canvas id="chart-asset" width="400" height="300"></canvas>
            <div class="chart-legend" id="legend-asset"></div>
          </div>
          <div class="card chart-card">
            <h3>Position Type Breakdown</h3>
            <canvas id="chart-position" width="400" height="300"></canvas>
            <div class="chart-legend" id="legend-pos"></div>
          </div>
        </div>

        <span class="section-label">Active &amp; Completed Positions</span>
        <div id="deal-cards" class="deal-cards"></div>
      </div>

      <!-- Real Estate Panel -->
      <div class="tab-panel" id="panel-realestate">
        <div class="grid-3" style="margin-bottom: 2rem;">
          <div class="card stat-card">
            <span class="stat-label">Total Units</span>
            <span class="stat-value">37</span>
          </div>
          <div class="card stat-card">
            <span class="stat-label">Active Syndications</span>
            <span class="stat-value">2</span>
          </div>
          <div class="card stat-card">
            <span class="stat-label">Tax Strategy</span>
            <span class="stat-value">Cost Seg</span>
          </div>
        </div>

        <!-- Cherry St Apartments -->
        <article class="re-deal-card">
          <div class="re-deal-header">
            <div>
              <h3>Cherry St Apartments</h3>
              <span class="re-deal-location">Chico, CA</span>
            </div>
            <span class="re-deal-status re-deal-active">Active</span>
          </div>
          <div class="re-deal-body">
            <div class="re-deal-stats">
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Units</span>
                <span class="re-deal-stat-value">20</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Acquired</span>
                <span class="re-deal-stat-value">2025</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Rent at Closing</span>
                <span class="re-deal-stat-value">$13,760/mo</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Rent Today</span>
                <span class="re-deal-stat-value rent-highlight">$16,200/mo</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Portfolio Rent Lift</span>
                <span class="re-deal-stat-value rent-highlight">+18%</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Rehabbed Unit Rent</span>
                <span class="re-deal-stat-value rent-highlight">$725 &rarr; $1,250</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Distribution</span>
                <span class="re-deal-stat-value">Quarterly</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Current Yield</span>
                <span class="re-deal-stat-value rent-highlight">5% Annual</span>
              </div>
            </div>
            <div class="re-deal-description">
              <p>20-unit workforce housing community in Chico, CA. A portion of the units are undergoing full gut rehabs, repositioning them from $725/mo to $1,250/mo. The remaining units are being brought to market rents through operational improvements: normalizing leases, implementing RUBS for utility cost recovery, and maintaining high occupancy through active leasing.</p>
              <p style="margin-top: 0.75rem;">The long-term strategy is to build equity through cashflow and forced appreciation, positioning the asset for a 1031 exchange into a larger property - chasing more cashflow while capturing the upside from repositioning.</p>
              <p style="margin-top: 0.75rem;">Investors receive regular updates on leasing activity, rent collections, maintenance, and operational priorities.</p>
            </div>
            <!-- Property Exterior -->
            <div class="re-deal-hero">
              <img src="/photos/cherry/exterior.jpg" alt="Cherry St Apartments - Chico, CA" loading="lazy" />
            </div>

            <!-- Before & After -->
            <div class="before-after-section">
              <span class="section-label" style="margin-bottom: 1rem;">Before &amp; After</span>
              <div class="before-after-grid">
                <div class="ba-pair">
                  <div class="ba-img">
                    <span class="ba-label ba-before">Before</span>
                    <img src="/photos/cherry/before-kitchen.jpg" alt="Kitchen before renovation" loading="lazy" />
                  </div>
                  <div class="ba-img">
                    <span class="ba-label ba-after">After</span>
                    <img src="/photos/cherry/after-kitchen.jpg" alt="Kitchen after renovation" loading="lazy" />
                  </div>
                </div>
                <div class="ba-pair">
                  <div class="ba-img">
                    <span class="ba-label ba-before">Before</span>
                    <img src="/photos/cherry/before-bathroom.jpg" alt="Bathroom before renovation" loading="lazy" />
                  </div>
                  <div class="ba-img">
                    <span class="ba-label ba-after">After</span>
                    <img src="/photos/cherry/after-bathroom.jpg" alt="Bathroom after renovation" loading="lazy" />
                  </div>
                </div>
              </div>
            </div>
          </div>
        </article>

        <!-- Memphis STR Portfolio -->
        <article class="re-deal-card" style="margin-top: 1.5rem;">
          <div class="re-deal-header">
            <div>
              <h3>Memphis STR Portfolio</h3>
              <span class="re-deal-location">Memphis, TN</span>
            </div>
            <span class="re-deal-status re-deal-paused">Distributions Paused</span>
          </div>
          <div class="re-deal-body">
            <div class="re-deal-stats">
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Units</span>
                <span class="re-deal-stat-value">17</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Acquired</span>
                <span class="re-deal-stat-value">2023</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Strategy</span>
                <span class="re-deal-stat-value">Rehab to STR</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Distribution</span>
                <span class="re-deal-stat-value">Paused</span>
              </div>
            </div>
            <div class="re-deal-description">
              <p>17-unit portfolio acquired and fully rehabbed, converted to furnished short-term rentals generating income from nightly and monthly bookings. Distributions are currently paused.</p>
            </div>
            <div class="re-deal-hero">
              <img src="/photos/memphis/str-after.jpg" alt="Memphis STR unit - post rehab" loading="lazy" />
            </div>
          </div>
        </article>

      </div>

      <!-- Energy Panel -->
      <div class="tab-panel" id="panel-energy">
        <div class="grid-3" style="margin-bottom: 2rem;">
          <div class="card stat-card">
            <span class="stat-label">Programs Since 2021</span>
            <span class="stat-value">6</span>
          </div>
          <div class="card stat-card">
            <span class="stat-label">Capital Deployed</span>
            <span class="stat-value">$5.7M+</span>
          </div>
          <div class="card stat-card">
            <span class="stat-label">Wells Drilled</span>
            <span class="stat-value">30+</span>
          </div>
        </div>

        <div class="re-deal-description" style="margin-bottom: 2rem; max-width: 70ch;">
          <p>Direct working interests in oil and gas drilling programs. Investors receive monthly distributions from well production and significant first-year tax deductions through intangible drilling costs (IDC).</p>
          <p style="margin-top: 0.75rem;">Early investments provided valuable operational learning. As a result, we have shifted toward partnering with larger operators with stronger balance sheets, repeatable drilling programs, and proven production histories.</p>
        </div>

        <!-- Oil Fund VI -->
        <article class="re-deal-card">
          <div class="re-deal-header">
            <div>
              <h3>Oil Fund VI - Rush Creek</h3>
              <span class="re-deal-location">2025</span>
            </div>
            <span class="re-deal-status re-deal-active">Producing</span>
          </div>
          <div class="re-deal-body">
            <div class="re-deal-stats">
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Capital Raised</span>
                <span class="re-deal-stat-value">$1,765,000</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Wells</span>
                <span class="re-deal-stat-value">11</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Production</span>
                <span class="re-deal-stat-value">~30 bbl/day/well</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Status</span>
                <span class="re-deal-stat-value">At pro forma</span>
              </div>
            </div>
            <div class="re-deal-description">
              <p>Most recent program reflecting our refined operator selection process. Eleven wells with Rush Creek Resources, currently producing at approximately pro forma levels.</p>
            </div>
          </div>
        </article>

        <!-- Oil Fund V -->
        <article class="re-deal-card" style="margin-top: 1.5rem;">
          <div class="re-deal-header">
            <div>
              <h3>Oil Fund V - DW Energy / Fulcrum</h3>
              <span class="re-deal-location">2024</span>
            </div>
            <span class="re-deal-status re-deal-active">Producing</span>
          </div>
          <div class="re-deal-body">
            <div class="re-deal-stats">
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Capital Raised</span>
                <span class="re-deal-stat-value">$900,000</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Wells</span>
                <span class="re-deal-stat-value">4</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Capital Returned</span>
                <span class="re-deal-stat-value rent-highlight">~17.5%</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Production</span>
                <span class="re-deal-stat-value">~200 bbl/day/well</span>
              </div>
            </div>
            <div class="re-deal-description">
              <p>Transition toward larger, more established operators. Wells required remediation work after initial operational challenges but are currently producing. Marked a shift in our operator selection approach.</p>
            </div>
          </div>
        </article>

        <!-- Oil Fund IV -->
        <article class="re-deal-card" style="margin-top: 1.5rem;">
          <div class="re-deal-header">
            <div>
              <h3>Oil Fund IV - DES</h3>
              <span class="re-deal-location">2023</span>
            </div>
            <span class="re-deal-status re-deal-loss">Total Loss</span>
          </div>
          <div class="re-deal-body">
            <div class="re-deal-stats">
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Capital Raised</span>
                <span class="re-deal-stat-value">$1,165,000</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Production Revenue</span>
                <span class="re-deal-stat-value">$0</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">IDC Deduction</span>
                <span class="re-deal-stat-value">100%</span>
              </div>
            </div>
            <div class="re-deal-description">
              <p>Wells experienced significant mechanical failures and operational issues resulting in a total loss of invested capital. Investors received 100% IDC deductions in the first year. This investment reinforced the importance of operator quality and operational execution when selecting drilling partners.</p>
            </div>
          </div>
        </article>

        <!-- Oil Fund III -->
        <article class="re-deal-card" style="margin-top: 1.5rem;">
          <div class="re-deal-header">
            <div>
              <h3>Oil Fund III - Panex</h3>
              <span class="re-deal-location">2023</span>
            </div>
            <span class="re-deal-status re-deal-active">Producing</span>
          </div>
          <div class="re-deal-body">
            <div class="re-deal-stats">
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Capital Raised</span>
                <span class="re-deal-stat-value">$735,000</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Wells</span>
                <span class="re-deal-stat-value">3</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Capital Returned</span>
                <span class="re-deal-stat-value rent-highlight">~10.7%</span>
              </div>
            </div>
            <div class="re-deal-description">
              <p>Continued partnership with the Panex operating team. One well was replaced during drilling due to issues - operator delivered three completed producing wells as planned. Wells remain in production.</p>
            </div>
          </div>
        </article>

        <!-- Oil Fund II -->
        <article class="re-deal-card" style="margin-top: 1.5rem;">
          <div class="re-deal-header">
            <div>
              <h3>Oil Fund II - Panex</h3>
              <span class="re-deal-location">2022</span>
            </div>
            <span class="re-deal-status re-deal-active">Producing</span>
          </div>
          <div class="re-deal-body">
            <div class="re-deal-stats">
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Capital Raised</span>
                <span class="re-deal-stat-value">$1,004,000</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Wells</span>
                <span class="re-deal-stat-value">9</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Capital Returned</span>
                <span class="re-deal-stat-value rent-highlight">~15%</span>
              </div>
            </div>
            <div class="re-deal-description">
              <p>Expanded drilling program with Panex. All nine wells successfully drilled, completed, and remain in production with continued distributions.</p>
            </div>
          </div>
        </article>

        <!-- Oil Fund I -->
        <article class="re-deal-card" style="margin-top: 1.5rem;">
          <div class="re-deal-header">
            <div>
              <h3>Oil Fund I - Panex</h3>
              <span class="re-deal-location">2021</span>
            </div>
            <span class="re-deal-status re-deal-active">Producing</span>
          </div>
          <div class="re-deal-body">
            <div class="re-deal-stats">
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Capital Raised</span>
                <span class="re-deal-stat-value">$175,000</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Wells</span>
                <span class="re-deal-stat-value">3</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Capital Returned</span>
                <span class="re-deal-stat-value rent-highlight">~80%</span>
              </div>
            </div>
            <div class="re-deal-description">
              <p>First drilling program. Three wells successfully drilled and completed, all still producing. Approximately 80% of invested capital returned to investors to date with ongoing production revenue.</p>
            </div>
          </div>
        </article>

      </div>
    </div>
  </section>

  <section style="padding: 0 0 3rem;">
    <div class="container">
      <p class="disclaimer">Past performance is not indicative of future results. All investments involve risk, including total loss of principal. Distribution schedules are targets and not guaranteed. IDC deductions depend on individual tax circumstances — consult your tax advisor. The information presented is for informational purposes only and does not constitute an offer to sell or solicitation of an offer to buy any securities. These materials are intended for accredited investors only.</p>
    </div>
  </section>
</Layout>

<style>
  .hero-sm {
    padding: 5rem 0 2rem;
  }
  .hero-sm h1 { margin: 0.5rem 0 1rem; }
  .hero-sm p { font-size: 1.125rem; max-width: 60ch; }

  .stat-card {
    text-align: center;
    padding: 1.5rem;
  }
  .stat-value {
    display: block;
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--accent);
    line-height: 1;
    margin-top: 0.5rem;
  }
  .stat-label {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* Strategy Tabs */
  .strategy-tabs {
    display: flex;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: 2rem;
    background: var(--bg-card);
  }

  .strategy-tab {
    flex: 1;
    padding: 0.875rem 1rem;
    background: transparent;
    border: none;
    color: var(--text-secondary);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition);
    border-right: 1px solid var(--border);
  }

  .strategy-tab:last-child {
    border-right: none;
  }

  .strategy-tab:hover {
    color: var(--text-primary);
    background: var(--bg-elevated);
  }

  .strategy-tab.active {
    background: var(--accent);
    color: #fff;
  }

  .tab-panel {
    display: none;
  }

  .tab-panel.active {
    display: block;
  }

  /* Real Estate Deal Cards */
  .re-deal-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .re-deal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .re-deal-header h3 {
    font-size: 1.25rem;
    margin: 0;
  }

  .re-deal-location {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .re-deal-status {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.3em 0.75em;
    border-radius: 999px;
  }

  .re-deal-active {
    background: rgba(25, 135, 84, 0.12);
    color: #198754;
  }

  .re-deal-paused {
    background: rgba(196, 138, 90, 0.15);
    color: var(--accent);
  }

  .re-deal-loss {
    background: rgba(220, 53, 69, 0.12);
    color: #dc3545;
  }

  .re-deal-body {
    padding: 1.5rem;
  }

  .re-deal-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 768px) {
    .re-deal-stats {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .re-deal-stat {
    display: flex;
    flex-direction: column;
  }

  .re-deal-stat-label {
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-bottom: 0.2rem;
  }

  .re-deal-stat-value {
    font-size: 0.9375rem;
    font-weight: 500;
  }

  .rent-highlight {
    color: var(--accent);
  }

  .re-deal-description {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .re-deal-description p {
    max-width: 100%;
  }

  .re-deal-photos {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .re-deal-hero {
    margin-top: 1.5rem;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .re-deal-hero img {
    width: 100%;
    height: auto;
    display: block;
  }

  .before-after-section {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .before-after-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .ba-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .ba-img {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .ba-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ba-label {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.25em 0.6em;
    border-radius: var(--radius-sm);
  }

  .ba-before {
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
  }

  .ba-after {
    background: var(--accent);
    color: #fff;
  }

  .re-deal-photos:empty {
    display: none;
  }

  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  .chart-card {
    padding: 1.5rem;
    overflow: hidden;
  }
  .chart-card canvas {
    max-width: 100%;
    height: auto !important;
  }
  .chart-card h3 {
    font-size: 1.125rem;
    margin-bottom: 1rem;
  }
  .chart-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.75rem;
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  @media (max-width: 400px) {
    .chart-card {
      padding: 1rem;
    }
  }

  .deal-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
  }

  /* Deal card styles */
  :global(.deal-card) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  :global(.deal-header) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    color: #fff;
    font-size: 0.875rem;
    font-weight: 500;
  }
  :global(.deal-tags) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  :global(.deal-tag) {
    font-size: 0.6875rem;
    padding: 0.2em 0.5em;
    border-radius: var(--radius-sm);
    background: rgba(255,255,255,0.15);
    color: #fff;
  }
  :global(.deal-tag-paid) {
    background: #198754;
  }
  :global(.deal-body) {
    padding: 1rem;
  }
  :global(.deal-grid) {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-top: 0.75rem;
  }
  @media (max-width: 768px) {
    :global(.deal-grid) {
      grid-template-columns: 1fr 1fr;
    }
    .strategy-tabs {
      flex-direction: column;
    }
    .strategy-tab {
      border-right: none;
      border-bottom: 1px solid var(--border);
    }
    .strategy-tab:last-child {
      border-bottom: none;
    }
  }
  :global(.deal-field) {
    display: flex;
    flex-direction: column;
    font-size: 0.8125rem;
  }
  :global(.deal-field-label) {
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-bottom: 0.15rem;
  }
  :global(.deal-rates) {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--border);
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }
  :global(.deal-rates-title) {
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-bottom: 0.25rem;
  }
</style>

<!-- Tab switching -->
<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var tabs = document.querySelectorAll('.strategy-tab');
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        tabs.forEach(function(t) { t.classList.remove('active'); });
        tab.classList.add('active');
        document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.remove('active'); });
        var panel = document.getElementById('panel-' + tab.getAttribute('data-tab'));
        if (panel) panel.classList.add('active');
      });
    });
  });
</script>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  const PREF_COLOR = '#c48a5a';
  const MEZZ_COLOR = '#7a9e7e';
  const PAID_COLOR = '#6b655a';

  const ASSET_COLORS = {
    'Multifamily': '#c48a5a',
    'Industrial': '#5a8f6e',
    'Retail': '#d4a054',
    'Medical Office': '#7b6b99',
    'Manufactured Housing': '#c4785a',
    'Student Housing': '#5a7fa0',
  };

  const POS_COLORS = {
    'Preferred Equity': PREF_COLOR,
    'Mezzanine Debt': MEZZ_COLOR,
  };

  const fmtMoney = (n) => Number(n).toLocaleString(undefined, { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });

  fetch('/pccf-data.json')
    .then(r => r.json())
    .then(({ meta, deals }) => {
      // KPIs
      document.getElementById('kpi-size').textContent = fmtMoney(meta.portfolioSize);
      document.getElementById('kpi-yield').textContent = meta.grossYield.toFixed(1) + '%';
      document.getElementById('kpi-ltv').textContent = meta.ltv + '%';

      // Pills
      const pillsEl = document.getElementById('pccf-pills');
      const totals = deals.reduce((a, d) => {
        const amt = Number(d.amt) || 0;
        if (d.paidOff) {
          a['Paid Off'] = (a['Paid Off'] || 0) + amt;
          return a;
        }
        const key = /mezz/i.test(d.posType || '') ? 'Mezzanine Debt' : 'Preferred Equity';
        a[key] = (a[key] || 0) + amt;
        return a;
      }, {});

      const makePill = (name, val, color) => {
        const span = document.createElement('span');
        span.style.cssText = `display:inline-flex;align-items:center;gap:0.375rem;font-size:0.8125rem;padding:0.4rem 0.75rem;border-radius:999px;border:1px solid var(--border);background:var(--bg-elevated);color:var(--text-secondary);`;
        span.innerHTML = `<span style="width:8px;height:8px;border-radius:2px;background:${color};display:inline-block;"></span>${name}: <strong style="color:var(--text-primary);">${fmtMoney(val)}</strong>`;
        return span;
      };

      pillsEl.appendChild(makePill('Preferred Equity', totals['Preferred Equity'] || 0, PREF_COLOR));
      pillsEl.appendChild(makePill('Mezzanine Debt', totals['Mezzanine Debt'] || 0, MEZZ_COLOR));
      pillsEl.appendChild(makePill('Paid Off', totals['Paid Off'] || 0, PAID_COLOR));

      // Charts - detect theme for colors
      const isLight = document.documentElement.getAttribute('data-theme') === 'light' ||
        (!document.documentElement.getAttribute('data-theme') && window.matchMedia('(prefers-color-scheme: light)').matches);
      Chart.defaults.color = isLight ? '#5c574d' : '#a09a8e';
      Chart.defaults.borderColor = isLight ? 'rgba(26,25,21,0.08)' : 'rgba(242,239,232,0.06)';

      const byKey = (key) => deals.filter(d => !d.paidOff).reduce((a, d) => {
        const k = d[key] || 'Other';
        a[k] = (a[k] || 0) + (Number(d.amt) || 0);
        return a;
      }, {});

      const assetMap = byKey('asset');
      const assetLabels = Object.keys(assetMap);
      const assetData = assetLabels.map(k => assetMap[k]);
      const assetColors = assetLabels.map(k => ASSET_COLORS[k] || '#888');

      const posMap = byKey('posType');
      const posLabels = Object.keys(posMap);
      const posData = posLabels.map(k => posMap[k]);
      const posColors = posLabels.map(k => POS_COLORS[k] || '#888');

      const makePie = (canvasId, labels, data, colors) => {
        return new Chart(document.getElementById(canvasId), {
          type: 'doughnut',
          data: { labels, datasets: [{ data, backgroundColor: colors, borderWidth: 0 }] },
          options: {
            cutout: '55%',
            plugins: {
              legend: { display: false },
              tooltip: {
                backgroundColor: isLight ? '#ffffff' : '#1e1d1a',
                titleColor: isLight ? '#1a1915' : '#f2efe8',
                bodyColor: isLight ? '#5c574d' : '#a09a8e',
                borderColor: isLight ? 'rgba(26,25,21,0.12)' : 'rgba(242,239,232,0.1)',
                borderWidth: 1,
                callbacks: {
                  label: (c) => {
                    const v = c.raw;
                    const total = c.dataset.data.reduce((x, y) => x + y, 0);
                    const p = ((v / total) * 100).toFixed(1) + '%';
                    return `${c.label}: ${fmtMoney(v)} (${p})`;
                  }
                }
              }
            }
          }
        });
      };

      makePie('chart-asset', assetLabels, assetData, assetColors);
      makePie('chart-position', posLabels, posData, posColors);

      const legend = (elId, labels, colors, data) => {
        const el = document.getElementById(elId);
        const total = data.reduce((a, b) => a + b, 0) || 1;
        el.innerHTML = labels.map((l, i) => {
          const p = ((data[i] / total) * 100).toFixed(0);
          return `<span style="display:flex;align-items:center;gap:0.35rem;"><span style="width:8px;height:8px;border-radius:2px;background:${colors[i]};display:inline-block;"></span>${l}: ${p}%</span>`;
        }).join('');
      };

      legend('legend-asset', assetLabels, assetColors, assetData);
      legend('legend-pos', posLabels, posColors, posData);

      // Deal Cards
      const cardsEl = document.getElementById('deal-cards');
      deals.forEach(d => {
        let headerColor = /mezz/i.test(d.posType || '') ? MEZZ_COLOR : PREF_COLOR;
        if (d.paidOff) headerColor = PAID_COLOR;

        const rates = Array.isArray(d.rate) ? d.rate : (typeof d.rate === 'string' ? d.rate.split(',') : []);
        const cleanRates = rates.map(s => String(s).replace(/^"+|"+$/g, '').trim()).filter(Boolean);

        const card = document.createElement('article');
        card.className = 'deal-card';
        card.innerHTML = `
          <div class="deal-header" style="background:${headerColor};">
            <div><strong>${d.num || ''}</strong> - ${d.location || ''}</div>
            <div class="deal-tags">
              ${d.paidOff ? '<span class="deal-tag deal-tag-paid">Paid Off</span>' : ''}
              <span class="deal-tag">${d.asset || ''}</span>
            </div>
          </div>
          <div class="deal-body">
            <span class="badge">${d.posType || ''}</span>
            <div class="deal-grid">
              <div class="deal-field"><span class="deal-field-label">Position Amount</span>${fmtMoney(d.amt || 0)}</div>
              <div class="deal-field"><span class="deal-field-label">Combined LTV/LTC</span>${d.ltv !== undefined ? d.ltv + '%' : ''}</div>
              <div class="deal-field"><span class="deal-field-label">Est. Gross YTM</span>${d.ytm !== undefined ? d.ytm + '%' : ''}</div>
              <div class="deal-field"><span class="deal-field-label">Term</span>${d.term || ''}</div>
              <div class="deal-field"><span class="deal-field-label">Security</span>${d.security || ''}</div>
              <div class="deal-field"><span class="deal-field-label">Takeout Strategy</span>${d.takeout || ''}</div>
              <div class="deal-field"><span class="deal-field-label">Origination Date</span>${d.date || ''}</div>
            </div>
            ${cleanRates.length ? `
              <div class="deal-rates">
                <div class="deal-rates-title">Rate Details</div>
                ${cleanRates.map(r => '&bull; ' + r).join('<br/>')}
              </div>
            ` : ''}
            ${d.notes ? `<div class="deal-rates" style="border-top:none;padding-top:0.25rem;"><div class="deal-rates-title">Notes</div>${d.notes}</div>` : ''}
          </div>
        `;
        cardsEl.appendChild(card);
      });
    })
    .catch(e => console.error('PCCF data error:', e));
</script>
