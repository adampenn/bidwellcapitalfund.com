  const ASSET_COLORS = {
    'Multifamily': '#c48a5a',
    'Industrial': '#5a8f6e',
    'Retail': '#d4a054',
    'Medical Office': '#7b6b99',
    'Manufactured Housing': '#c4785a',
    'Student Housing': '#5a7fa0',
  };

  const POS_COLORS = {
    'Preferred Equity': PREF_COLOR,
    'Mezzanine Debt': MEZZ_COLOR,
  };

  const fmtMoney = (n) => Number(n).toLocaleString(undefined, { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });

  // Accepts either a string (e.g. "May 2024"), a number, or a numeric string
  // representing an Excel serial date (days since 1899-12-30). Returns "Mon YYYY".
  const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const fmtDate = (v) => {
    if (v === null || v === undefined || v === '') return '';
    let n;
    if (typeof v === 'number' && isFinite(v)) n = v;
    else if (typeof v === 'string' && v.trim() !== '' && !isNaN(Number(v))) n = Number(v);
    if (n !== undefined) {
      // Excel epoch is 1899-12-30 (accounting for the 1900 leap year bug).
      const ms = Date.UTC(1899, 11, 30) + n * 86400000;
      const d = new Date(ms);
      return MONTHS[d.getUTCMonth()] + ' ' + d.getUTCFullYear();
    }
    return String(v);
  };

  // Coerce string booleans like "true"/"false" (which spreadsheet exports emit)
  // back to real booleans. Anything truthy that isn't the string "false" passes.
  const toBool = (v) => {
    if (typeof v === 'boolean') return v;
    if (typeof v === 'string') return v.trim().toLowerCase() === 'true';
    return Boolean(v);
  };

  fetch('/pccf-data.json')
    .then(r => r.json())
    .then(payload => {
      // Accept either { meta, deals } or a flat array of deals (spreadsheet exports
      // are usually flat). If meta is missing, compute it from the active deals.
      let meta, deals;
      if (Array.isArray(payload)) {
        deals = payload;
        meta = null;
      } else {
        meta = payload.meta || null;
        deals = Array.isArray(payload.deals) ? payload.deals : [];
      }

      // Normalize each deal: stringy paidOff -> boolean, stringy paidOffDate -> number.
      deals = deals.map(d => ({ ...d, paidOff: toBool(d.paidOff) }));

      // If meta wasn't provided, derive it from non-paid-off deals.
      if (!meta) {
        const active = deals.filter(d => !d.paidOff);
        const totalAmt = active.reduce((a, d) => a + (Number(d.amt) || 0), 0);
        const wAvg = (key) => totalAmt
          ? active.reduce((a, d) => a + (Number(d.amt) || 0) * (Number(d[key]) || 0), 0) / totalAmt
          : 0;
        meta = {
          portfolioSize: totalAmt,
          grossYield: Number(wAvg('ytm').toFixed(1)),
          ltv: Math.round(wAvg('ltv')),
        };
      }

      // KPIs
      document.getElementById('kpi-size').textContent = fmtMoney(meta.portfolioSize);
      document.getElementById('kpi-yield').textContent = meta.grossYield.toFixed(1) + '%';
      document.getElementById('kpi-ltv').textContent = meta.ltv + '%';

      // Pills
      const pillsEl = document.getElementById('pccf-pills');
      const totals = deals.reduce((a, d) => {
        const amt = Number(d.amt) || 0;
        if (d.paidOff) {
          a['Paid Off'] = (a['Paid Off'] || 0) + amt;
          return a;
        }
        const key = /mezz/i.test(d.posType || '') ? 'Mezzanine Debt' : 'Preferred Equity';
        a[key] = (a[key] || 0) + amt;
        return a;
      }, {});

      const makePill = (name, val, color) => {
        const span = document.createElement('span');
        span.style.cssText = `display:inline-flex;align-items:center;gap:0.375rem;font-size:0.8125rem;padding:0.4rem 0.75rem;border-radius:999px;border:1px solid var(--border);background:var(--bg-elevated);color:var(--text-secondary);`;
        span.innerHTML = `<span style="width:8px;height:8px;border-radius:2px;background:${color};display:inline-block;"></span>${name}: <strong style="color:var(--text-primary);">${fmtMoney(val)}</strong>`;
        return span;
      };

      pillsEl.appendChild(makePill('Preferred Equity', totals['Preferred Equity'] || 0, PREF_COLOR));
      pillsEl.appendChild(makePill('Mezzanine Debt', totals['Mezzanine Debt'] || 0, MEZZ_COLOR));
      pillsEl.appendChild(makePill('Paid Off', totals['Paid Off'] || 0, PAID_COLOR));

      // Charts - detect theme for colors
      const isLight = document.documentElement.getAttribute('data-theme') === 'light' ||
        (!document.documentElement.getAttribute('data-theme') && window.matchMedia('(prefers-color-scheme: light)').matches);
      Chart.defaults.color = isLight ? '#5c574d' : '#a09a8e';
      Chart.defaults.borderColor = isLight ? 'rgba(26,25,21,0.08)' : 'rgba(242,239,232,0.06)';

      const byKey = (key) => deals.filter(d => !d.paidOff).reduce((a, d) => {
        const k = d[key] || 'Other';
        a[k] = (a[k] || 0) + (Number(d.amt) || 0);
        return a;
      }, {});

      const assetMap = byKey('asset');
      const assetLabels = Object.keys(assetMap);
      const assetData = assetLabels.map(k => assetMap[k]);
      const assetColors = assetLabels.map(k => ASSET_COLORS[k] || '#888');

      const posMap = byKey('posType');
      const posLabels = Object.keys(posMap);
      const posData = posLabels.map(k => posMap[k]);
      const posColors = posLabels.map(k => POS_COLORS[k] || '#888');

      const makePie = (canvasId, labels, data, colors) => {
        return new Chart(document.getElementById(canvasId), {
          type: 'doughnut',
          data: { labels, datasets: [{ data, backgroundColor: colors, borderWidth: 0 }] },
          options: {
            cutout: '55%',
            plugins: {
              legend: { display: false },
              tooltip: {
                backgroundColor: isLight ? '#ffffff' : '#1e1d1a',
                titleColor: isLight ? '#1a1915' : '#f2efe8',
                bodyColor: isLight ? '#5c574d' : '#a09a8e',
                borderColor: isLight ? 'rgba(26,25,21,0.12)' : 'rgba(242,239,232,0.1)',
                borderWidth: 1,
                callbacks: {
                  label: (c) => {
                    const v = c.raw;
                    const total = c.dataset.data.reduce((x, y) => x + y, 0);
                    const p = ((v / total) * 100).toFixed(1) + '%';
                    return `${c.label}: ${fmtMoney(v)} (${p})`;
                  }
                }
              }
            }
          }
        });
      };

      makePie('chart-asset', assetLabels, assetData, assetColors);
      makePie('chart-position', posLabels, posData, posColors);

      const legend = (elId, labels, colors, data) => {
        const el = document.getElementById(elId);
        const total = data.reduce((a, b) => a + b, 0) || 1;
        el.innerHTML = labels.map((l, i) => {
          const p = ((data[i] / total) * 100).toFixed(0);
          return `<span style="display:flex;align-items:center;gap:0.35rem;"><span style="width:8px;height:8px;border-radius:2px;background:${colors[i]};display:inline-block;"></span>${l}: ${p}%</span>`;
        }).join('');
      };

      legend('legend-asset', assetLabels, assetColors, assetData);
      legend('legend-pos', posLabels, posColors, posData);

      // Deal Cards
      const cardsEl = document.getElementById('deal-cards');
      const escapeHtml = s => String(s == null ? '' : s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
      // Allow narrative bullets to contain inline markup like <strong>; we trust our own JSON.
      // For paragraphs that came from user-editable notes, escapeHtml is used instead.
      const renderBullet = item => `<li>${item}</li>`;

      deals.forEach(d => {
        let headerColor = /mezz/i.test(d.posType || '') ? MEZZ_COLOR : PREF_COLOR;
        if (d.paidOff) headerColor = PAID_COLOR;
        if (d.watchList) headerColor = MEZZ_COLOR;

        const rates = Array.isArray(d.rate) ? d.rate : (typeof d.rate === 'string' ? d.rate.split(',') : []);
        const cleanRates = rates.map(s => String(s).replace(/^"+|"+$/g, '').trim()).filter(Boolean);

        // Header title prefers a deal name when present, otherwise falls back to location
        const headerTitle = d.name
          ? `<strong>${d.num || ''}</strong> &mdash; ${escapeHtml(d.name)} <span class="deal-header-loc">(${escapeHtml(d.location || '')})</span>`
          : `<strong>${d.num || ''}</strong> - ${escapeHtml(d.location || '')}`;

        const tagsHtml = `
          ${d.paidOff ? '<span class="deal-tag deal-tag-paid">Paid Off</span>' : ''}
          ${d.watchList && !d.paidOff ? '<span class="deal-tag deal-tag-watch">Watch List</span>' : ''}
          <span class="deal-tag">${escapeHtml(d.asset || '')}</span>
        `;

        // Outcome callout (paid-off deals only)
        const outcomeHtml = (d.paidOff && d.outcome) ? `
          <div class="deal-outcome">
            <div class="deal-outcome-stats">
              ${d.outcome.returnPct !== undefined ? `<div><span class="deal-outcome-num">${d.outcome.returnPct}%</span><span class="deal-outcome-lbl">Gross Return</span></div>` : ''}
              ${d.outcome.holdMonths !== undefined ? `<div><span class="deal-outcome-num">${d.outcome.holdMonths} mo</span><span class="deal-outcome-lbl">Hold</span></div>` : ''}
              ${d.outcome.exitVia ? `<div><span class="deal-outcome-num deal-outcome-num-sm">${escapeHtml(d.outcome.exitVia)}</span><span class="deal-outcome-lbl">Exit</span></div>` : ''}
            </div>
            ${d.outcome.narrative ? `<p class="deal-outcome-narrative">${escapeHtml(d.outcome.narrative)}</p>` : ''}
          </div>
        ` : '';

        const thesisHtml = (Array.isArray(d.thesis) && d.thesis.length) ? `
          <details class="deal-narrative">
            <summary><span class="deal-narrative-icon" aria-hidden="true">+</span> Details</summary>
            <ul class="deal-bullets">${d.thesis.map(renderBullet).join('')}</ul>
          </details>
        ` : '';

        const protectHtml = (Array.isArray(d.capitalProtection) && d.capitalProtection.length) ? `
          <details class="deal-narrative">
            <summary><span class="deal-narrative-icon" aria-hidden="true">+</span> Capital protection</summary>
            <ul class="deal-bullets">${d.capitalProtection.map(renderBullet).join('')}</ul>
          </details>
        ` : '';

        const updateHtml = d.updateNote ? `
          <div class="deal-update">
            <div class="deal-update-label">Update</div>
            <p>${escapeHtml(d.updateNote)}</p>
          </div>
        ` : '';

        const watchHtml = (d.watchList && d.watchListNote) ? `
          <div class="deal-watch-note">
            <div class="deal-update-label">Watch list status</div>
            <p>${escapeHtml(d.watchListNote)}</p>
          </div>
        ` : '';

        const card = document.createElement('article');
        card.className = 'deal-card';
        card.innerHTML = `
          <div class="deal-header" style="background:${headerColor};">
            <div>${headerTitle}</div>
            <div class="deal-tags">${tagsHtml}</div>
          </div>
          <div class="deal-body">
            <span class="badge">${escapeHtml(d.posType || '')}</span>
            <div class="deal-grid">
              <div class="deal-field"><span class="deal-field-label">Position Amount</span>${fmtMoney(d.amt || 0)}</div>
              <div class="deal-field"><span class="deal-field-label">Combined LTV/LTC</span>${d.ltv !== undefined ? d.ltv + '%' : ''}</div>
              <div class="deal-field"><span class="deal-field-label">Est. Gross YTM</span>${d.ytm !== undefined ? d.ytm + '%' : ''}</div>
              <div class="deal-field"><span class="deal-field-label">Term</span>${escapeHtml(d.term || '')}</div>
              <div class="deal-field"><span class="deal-field-label">Security</span>${escapeHtml(d.security || '')}</div>
              <div class="deal-field"><span class="deal-field-label">Takeout Strategy</span>${escapeHtml(d.takeout || '')}</div>
              <div class="deal-field"><span class="deal-field-label">Origination Date</span>${escapeHtml(d.date || '')}</div>
              ${d.paidOff && (d.paidOffDate || d.paidOffDate === 0) ? `<div class="deal-field"><span class="deal-field-label">Paid Off Date</span>${fmtDate(d.paidOffDate)}</div>` : ''}
            </div>
            ${outcomeHtml}
            ${updateHtml}
            ${watchHtml}
            ${thesisHtml}
            ${protectHtml}
            ${cleanRates.length ? `
              <details class="deal-narrative">
                <summary><span class="deal-narrative-icon" aria-hidden="true">+</span> Rate details</summary>
                <ul class="deal-bullets">${cleanRates.map(r => `<li>${escapeHtml(r)}</li>`).join('')}</ul>
              </details>
            ` : ''}
          </div>
        `;
        cardsEl.appendChild(card);
      });
    })
    .catch(e => console.error('PCCF data error:', e));
</script>
