---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Track Record - Bidwell Capital" description="Deal-by-deal transparency across all Bidwell Capital strategies.">
  <section class="hero-sm">
    <div class="container">
      <span class="section-label fade-up fade-up-1">Track Record</span>
      <h1 class="fade-up fade-up-2">Our strategies, transparently</h1>
      <p class="fade-up fade-up-3">We believe in full transparency. Below is a look at our active strategies and their performance. <a href="/about" style="color: var(--accent);">Learn more about how we invest &rarr;</a></p>
    </div>
  </section>

  <!-- Company-wide stat -->
  <section class="section" style="padding-top: 2rem; padding-bottom: 1rem;">
    <div class="container">
      <div class="grid-3">
        <div class="card stat-card">
          <span class="stat-label">Invested</span>
          <span class="stat-value">$12.5M+</span>
        </div>
        <div class="card stat-card">
          <span class="stat-label">Distributed</span>
          <span class="stat-value">$700K+</span>
        </div>
        <div class="card stat-card">
          <span class="stat-label">Investors</span>
          <span class="stat-value">103</span>
        </div>
      </div>
      <p class="disclaimer" style="margin-top: 1rem; text-align: center;">Past performance is not indicative of future results. All investments carry risk, including loss of principal.</p>
    </div>
  </section>

  <!-- Strategy Tabs -->
  <section class="section" style="padding-top: 1rem;">
    <div class="container">
      <div class="strategy-tabs" id="strategy-tabs">
        <button class="strategy-tab active" data-tab="credit">Private Credit</button>
        <button class="strategy-tab" data-tab="realestate">Multifamily Real Estate</button>
        <button class="strategy-tab" data-tab="energy">Oil &amp; Gas</button>
      </div>

      <!-- Private Credit Panel -->
      <div class="tab-panel active" id="panel-credit">
        <div class="grid-3" style="margin-bottom: 2rem;" id="kpi-grid">
          <div class="card stat-card">
            <span class="stat-label">Portfolio Size</span>
            <span class="stat-value" id="kpi-size">-</span>
          </div>
          <div class="card stat-card">
            <span class="stat-label">Gross Yield</span>
            <span class="stat-value" id="kpi-yield">-</span>
          </div>
          <div class="card stat-card">
            <span class="stat-label">Combined LTV/LTC</span>
            <span class="stat-value" id="kpi-ltv">-</span>
          </div>
        </div>

        <div class="re-deal-description" style="margin-bottom: 1.5rem;">
          <p>Bidwell Capital has deployed $4.7M into private credit through a fund-of-funds structure. The portfolio consists of preferred equity and mezzanine debt positions across multifamily, industrial, and other commercial real estate assets. The positions below represent the underlying portfolio exposure.</p>
        </div>

        <div class="pills" id="pccf-pills" style="margin-bottom: 1.5rem;"></div>

        <div class="grid-2" style="margin-bottom: 2rem;">
          <div class="card chart-card">
            <h3>Portfolio Asset Mix</h3>
            <canvas id="chart-asset" width="400" height="300"></canvas>
            <div class="chart-legend" id="legend-asset"></div>
          </div>
          <div class="card chart-card">
            <h3>Position Type Breakdown</h3>
            <canvas id="chart-position" width="400" height="300"></canvas>
            <div class="chart-legend" id="legend-pos"></div>
          </div>
        </div>

        <span class="section-label">Active &amp; Completed Positions</span>
        <div id="deal-cards" class="deal-cards"></div>
      </div>

      <!-- Real Estate Panel -->
      <div class="tab-panel" id="panel-realestate">
        <div class="grid-3" style="margin-bottom: 2rem;">
          <div class="card stat-card">
            <span class="stat-label">Total Units</span>
            <span class="stat-value">37</span>
          </div>
          <div class="card stat-card">
            <span class="stat-label">Active Syndications</span>
            <span class="stat-value">2</span>
          </div>
          <div class="card stat-card">
            <span class="stat-label">Tax Strategy</span>
            <span class="stat-value">Cost Seg</span>
          </div>
        </div>

        <!-- Cherry St Apartments -->
        <article class="re-deal-card">
          <div class="re-deal-header">
            <div>
              <h3>Cherry St Apartments</h3>
              <span class="re-deal-location">Chico, CA</span>
            </div>
            <span class="re-deal-status re-deal-active">Active</span>
          </div>
          <div class="re-deal-body">
            <div class="re-deal-stats">
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Units</span>
                <span class="re-deal-stat-value">20</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Acquired</span>
                <span class="re-deal-stat-value">2025</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Rent at Closing</span>
                <span class="re-deal-stat-value">$13,760/mo</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Rent Today</span>
                <span class="re-deal-stat-value rent-highlight">$16,200/mo</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Portfolio Rent Lift</span>
                <span class="re-deal-stat-value rent-highlight">+18%</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Rehabbed Unit Rent</span>
                <span class="re-deal-stat-value rent-highlight">$725 &rarr; $1,250</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Distribution</span>
                <span class="re-deal-stat-value">Quarterly</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Current Yield</span>
                <span class="re-deal-stat-value rent-highlight">5% Annual</span>
              </div>
            </div>
            <div class="deal-split">
              <div class="re-deal-description">
                <p>20-unit workforce housing community in Chico, CA. A portion of the units are undergoing full gut rehabs, repositioning them from $725/mo to $1,250/mo. The remaining units are being brought to market rents through operational improvements: normalizing leases, implementing RUBS for utility cost recovery, and maintaining high occupancy through active leasing.</p>
                <p style="margin-top: 0.75rem;">The long-term strategy is to build equity through cashflow and forced appreciation, positioning the asset for a 1031 exchange into a larger property - chasing more cashflow while capturing the upside from repositioning.</p>
                <p style="margin-top: 0.75rem;">Investors receive regular updates on leasing activity, rent collections, maintenance, and operational priorities.</p>
              </div>
              <!-- Property Exterior -->
              <div class="re-deal-hero">
                <img src="/photos/cherry/exterior.jpg" alt="Cherry St Apartments - Chico, CA" loading="lazy" />
              </div>
            </div>

            <!-- Before & After -->
            <div class="before-after-section">
              <span class="section-label" style="margin-bottom: 1rem;">Before &amp; After</span>
              <div class="before-after-grid">
                <div class="ba-pair">
                  <div class="ba-img">
                    <span class="ba-label ba-before">Before</span>
                    <img src="/photos/cherry/before-kitchen.jpg" alt="Kitchen before renovation" loading="lazy" />
                  </div>
                  <div class="ba-img">
                    <span class="ba-label ba-after">After</span>
                    <img src="/photos/cherry/after-kitchen.jpg" alt="Kitchen after renovation" loading="lazy" />
                  </div>
                </div>
                <div class="ba-pair">
                  <div class="ba-img">
                    <span class="ba-label ba-before">Before</span>
                    <img src="/photos/cherry/before-bathroom.jpg" alt="Bathroom before renovation" loading="lazy" />
                  </div>
                  <div class="ba-img">
                    <span class="ba-label ba-after">After</span>
                    <img src="/photos/cherry/after-bathroom.jpg" alt="Bathroom after renovation" loading="lazy" />
                  </div>
                </div>
              </div>
            </div>
          </div>
        </article>

        <!-- Memphis STR Portfolio -->
        <article class="re-deal-card" style="margin-top: 1.5rem;">
          <div class="re-deal-header">
            <div>
              <h3>Memphis STR Portfolio</h3>
              <span class="re-deal-location">Memphis, TN</span>
            </div>
            <span class="re-deal-status re-deal-paused">Distributions Paused</span>
          </div>
          <div class="re-deal-body">
            <div class="re-deal-stats">
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Properties</span>
                <span class="re-deal-stat-value">4</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Total Units</span>
                <span class="re-deal-stat-value">15</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Acquired</span>
                <span class="re-deal-stat-value">2023</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Strategy</span>
                <span class="re-deal-stat-value">STR + Value-Add</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">STR Properties</span>
                <span class="re-deal-stat-value">3 (12 Units)</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Rehab Status</span>
                <span class="re-deal-stat-value rent-highlight">Complete</span>
              </div>
              <div class="re-deal-stat">
                <span class="re-deal-stat-label">Distribution</span>
                <span class="re-deal-stat-value">Paused</span>
              </div>
            </div>
            <div class="re-deal-description">
              <p>The fund acquired four multifamily properties totaling 15 units in Memphis throughout 2023. All four properties were fully rehabbed with new HVAC, electrical, plumbing, drywall, flooring, kitchens, and bathrooms. Three properties (963 New York St, 2033 Young Ave, and 2375 Forrest Ave) were converted into furnished short-term rentals operating on Airbnb, while 69 N Tucker is being leased as a long-term rental.</p>
              <p style="margin-top: 0.75rem;">The three STR properties have been generating revenue since late 2023, with 2375 Forrest Ave as the strongest performer consistently reaching 73 to 84% occupancy. The team sends detailed monthly investor updates covering occupancy, revenue, expenses, and property-level P&amp;Ls for full transparency.</p>
              <p style="margin-top: 0.75rem;">The fund is currently working to refinance all four properties to lower interest rates and return principal to investors. Distributions remain paused during this process.</p>
            </div>
            <!-- Property Before & Afters -->
            <div class="before-after-section">
              <span class="section-label" style="margin-bottom: 1rem;">Before &amp; After</span>
              <div class="properties-grid">

                <div class="property-ba">
                  <h4 class="property-ba-title">69 N Tucker</h4>
                  <div class="before-after-grid">
                    <div class="ba-pair">
                      <div class="ba-img">
                        <span class="ba-label ba-before">Before</span>
                        <img src="/photos/memphis/before-exterior.webp" alt="69 N Tucker exterior before renovation" loading="lazy" />
                      </div>
                      <div class="ba-img">
                        <span class="ba-label ba-after">After</span>
                        <img src="/photos/memphis/after-exterior.jpg" alt="69 N Tucker exterior after renovation" loading="lazy" />
                      </div>
                    </div>
                    <div class="ba-pair">
                      <div class="ba-img">
                        <span class="ba-label ba-before">Before</span>
                        <img src="/photos/memphis/before-kitchen.webp" alt="Kitchen before renovation" loading="lazy" />
                      </div>
                      <div class="ba-img">
                        <span class="ba-label ba-after">After</span>
                        <img src="/photos/memphis/after-kitchen.jpg" alt="Kitchen after renovation" loading="lazy" />
                      </div>
                    </div>
                    <div class="ba-pair">
                      <div class="ba-img">
                        <span class="ba-label ba-before">Before</span>
                        <img src="/photos/memphis/before-bathroom.webp" alt="Bathroom before renovation" loading="lazy" />
                      </div>
                      <div class="ba-img">
                        <span class="ba-label ba-after">After</span>
                        <img src="/photos/memphis/after-bathroom.jpg" alt="Bathroom after renovation" loading="lazy" />
                      </div>
                    </div>
                  </div>
                </div>

                <div class="property-ba">
                  <h4 class="property-ba-title">2375 Forrest Ave</h4>
                  <div class="before-after-grid">
                    <div class="ba-pair">
                      <div class="ba-img">
                        <span class="ba-label ba-before">Before</span>
                        <img src="/photos/memphis/forrest/before-exterior.jpg" alt="2375 Forrest Ave exterior before renovation" loading="lazy" />
                      </div>
                      <div class="ba-img">
                        <span class="ba-label ba-after">After</span>
                        <img src="/photos/memphis/forrest/after-exterior.jpg" alt="2375 Forrest Ave exterior after renovation" loading="lazy" />
                      </div>
                    </div>
                    <div class="ba-pair">
                      <div class="ba-img">
                        <span class="ba-label ba-before">Before</span>
                        <img src="/photos/memphis/forrest/before-kitchen.jpg" alt="Kitchen before renovation" loading="lazy" />
                      </div>
                      <div class="ba-img">
                        <span class="ba-label ba-after">After</span>
                        <img src="/photos/memphis/forrest/after-kitchen.jpg" alt="Kitchen after renovation" loading="lazy" />
                      </div>
                    </div>
                    <div class="ba-pair">
                      <div class="ba-img">
                        <span class="ba-label ba-before">Before</span>
                        <img src="/photos/memphis/forrest/before-bathroom.jpg" alt="Bathroom before renovation" loading="lazy" />
                      </div>
                      <div class="ba-img">
                        <span class="ba-label ba-after">After</span>
                        <img src="/photos/memphis/forrest/after-bathroom.jpg" alt="Bathroom after renovation" loading="lazy" />
                      </div>
                    </div>
                  </div>
                </div>

                <div class="property-ba">
                  <h4 class="property-ba-title">2033 Young Ave</h4>
                  <div class="before-after-grid">
                    <div class="ba-pair">
                      <div class="ba-img">
                        <span class="ba-label ba-before">Before</span>
                        <img src="/photos/memphis/young/before-exterior.webp" alt="2033 Young Ave exterior before renovation" loading="lazy" />
                      </div>
                      <div class="ba-img">
                        <span class="ba-label ba-after">After</span>
                        <img src="/photos/memphis/young/after-exterior.jpg" alt="2033 Young Ave exterior after renovation" loading="lazy" />
                      </div>
                    </div>
                    <div class="ba-pair">
                      <div class="ba-img">
                        <span class="ba-label ba-before">Before</span>
                        <img src="/photos/memphis/young/before-kitchen.webp" alt="Kitchen before renovation" loading="lazy" />
                      </div>
                      <div class="ba-img">
                        <span class="ba-label ba-after">After</span>
                        <img src="/photos/memphis/young/after-kitchen.jpg" alt="Kitchen after renovation" loading="lazy" />
                      </div>
                    </div>
                    <div class="ba-pair">
                      <div class="ba-img">
                        <span class="ba-label ba-before">Before</span>
                        <img src="/photos/memphis/young/before-bathroom.webp" alt="Bathroom before renovation" loading="lazy" />
                      </div>
                      <div class="ba-img">
                        <span class="ba-label ba-after">After</span>
                        <img src="/photos/memphis/young/after-bathroom.jpg" alt="Bathroom after renovation" loading="lazy" />
                      </div>
                    </div>
                  </div>
                </div>

                <div class="property-ba">
                  <h4 class="property-ba-title">963 New York St</h4>
                  <div class="before-after-grid">
                    <div class="ba-pair">
                      <div class="ba-img">
                        <span class="ba-label ba-before">Before</span>
                        <img src="/photos/memphis/newyork/before-exterior.jpg" alt="963 New York St exterior before renovation" loading="lazy" />
                      </div>
                      <div class="ba-img">
                        <span class="ba-label ba-after">After</span>
                        <img src="/photos/memphis/newyork/after-exterior.jpg" alt="963 New York St exterior after renovation" loading="lazy" />
                      </div>
                    </div>
                    <div class="ba-pair">
                      <div class="ba-img">
                        <span class="ba-label ba-before">Before</span>
                        <img src="/photos/memphis/newyork/before-kitchen.jpg" alt="Kitchen before renovation" loading="lazy" />
                      </div>
